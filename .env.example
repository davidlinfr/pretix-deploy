# Postgres credentials (à coller dans Coolify Environment Variables UI)
POSTGRES_DB=pretix
POSTGRES_USER=pretix
POSTGRES_PASSWORD=<openssl rand -base64 32>

# Django secret (security cookies, sessions)
DJANGO_SECRET=<openssl rand -base64 64>

# SMTP (envoi emails confirmations + reminders)
# Option Azure Communication Services (canon Fyneo) :
SMTP_HOST=smtp.azurecomm.net
SMTP_PORT=587
SMTP_USER=<azure-acs-user>
SMTP_PASSWORD=<azure-acs-password>

# Plugins activés via Dockerfile :
# - pretix-mollie  (paiements Mollie, plugin officiel)
# - pretix-oidc    (SSO Authentik, J+1 post-deploy)
